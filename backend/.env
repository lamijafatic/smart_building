# Database
# For local development we use SQLite (file-based, zero setup).
# For deployment switch to Postgres (Neon free tier) by changing
# the provider in prisma/schema.prisma to "postgresql" and using
# a connection string like:
#   postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="file:./dev.db"

# Server
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="15m"

# CORS
FRONTEND_URL="http://localhost:5173"
